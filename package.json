{
  "name": "vibe",
  "version": "0.1.0",
  "description": "아이디어부터 배포까지 한 터미널 안에서 끝내는 바이브 코딩 CLI",
  "type": "module",
  "bin": {
    "vibe": "dist/cli.js"
  },
  "files": [
